// Tayf – AI Workforce OS – Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  status       String   @default("active") // active | suspended
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business      Business?
  subscription  Subscription?
  referralCode  String         @unique @default(cuid())
  referredBy    String?
  conversations Conversation[]
  referrals     Referral[]     @relation("ReferrerUser")
}

model Business {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         String
  language     String  @default("ar")
  dialect      String  @default("sa")
  tone         String  @default("friendly")
  products     String?
  paymentLinks String?
  policies     String?
  whatsapp     String?
  telegramBotToken   String?  // توكن بوت تيليجرام
  telegramAgentType  String?  @default("support") // الموظف الافتراضي للتيليجرام

  agents BusinessAgent[]
}

model BusinessAgent {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  agentType    String
  isActive     Boolean  @default(true)
  customPrompt String?

  conversations Conversation[]

  @@unique([businessId, agentType])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      String   @default("trial")
  maxAgents Int      @default(1)
  status    String   @default("trial") // trial | active | expired | suspended
  trialEnds DateTime
  renewsAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String
  agent     BusinessAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referrer      User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referredEmail String
  status        String   @default("pending") // pending | completed
  reward        Int      @default(30)
  createdAt     DateTime @default(now())
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String        @default("open") // open | in_progress | resolved
  priority  String        @default("normal") // low | normal | high
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  replies   TicketReply[]
}

model TicketReply {
  id        String       @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  adminId   String
  content   String
  createdAt DateTime     @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  adminId   String
  title     String
  content   String
  audience  String   @default("all") // all | trial | active | specific
  createdAt DateTime @default(now())
}
